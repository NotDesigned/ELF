{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/docs_sync.py\"",
            "timeout": 10,
            "statusMessage": "Recording documentation-sync baseline"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/docs_sync.py\"",
            "timeout": 10,
            "statusMessage": "Checking documentation impact"
          }
        ]
      }
    ]
  }
}
